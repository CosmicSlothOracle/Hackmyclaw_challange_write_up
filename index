  <style>
    :root {
      --proto-1: #f6cd26; --proto-5: #bb7f57; --proto-6: #725956;
      --retro-black: #000000; --retro-0: #001418; --retro-1: #002024; --retro-2: #002c38;
      --retro-3: #143444; --retro-8: #6c706c; --retro-10: #a49484; --retro-11: #c4ac9c;
      --retro-12: #d8b0a8; --retro-13: #ecd4d0; --retro-14: #fcfcfc;
      --extra-3: #00b9be; --note-signal: #ff3e3e; --good: #6fcf97;
      --bg-main: var(--retro-0); --bg-panel: var(--retro-1); --bg-card: var(--retro-2);
      --text-main: var(--retro-11); --text-muted: var(--retro-10); --paper: var(--retro-13);
      --cream: var(--retro-12); --outline: var(--retro-black); --accent: var(--proto-1);
      --cat-evidence: var(--retro-5); --cat-fingerprint: var(--retro-6);
      --cat-commands: var(--retro-3); --cat-analyst: var(--retro-8);
      --ui-text-main: var(--paper); --ui-text-muted: var(--text-muted);
      --ui-heading: var(--paper); --ui-border: var(--outline);
      --ui-link: var(--accent); --ui-focus-ring: var(--accent);
      --ui-btn-bg: var(--retro-2); --ui-btn-fg: var(--paper);
      --ui-btn-border: var(--outline); --ui-btn-hover-bg: var(--retro-3);
      --ui-btn-hover-fg: var(--retro-14); --ui-btn-active-bg: var(--note-signal);
      --ui-btn-active-fg: var(--retro-black);
      --ui-field-bg: color-mix(in srgb, #06080d 72%, var(--accent) 28%);
      --ui-field-fg: #f2f5fc; --ui-field-border: color-mix(in srgb, #101218 62%, var(--accent) 38%);
      --segment-scrim: color-mix(in srgb, var(--bg-panel) 70%, transparent);
      --ascii-bg-opacity: 0.38;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body.readability-on {
      margin: 0; font-family: "Space Mono", monospace; font-size: 14px; line-height: 1.45;
      color: var(--ui-text-main);
      background: linear-gradient(180deg, var(--retro-1) 0%, var(--retro-0) 50%, var(--retro-black) 100%);
    }
    a { color: var(--ui-link); text-underline-offset: 3px; }
    a:focus-visible, button:focus-visible, select:focus-visible {
      outline: 2px solid var(--ui-focus-ring); outline-offset: 2px;
    }
    .skip-link {
      position: absolute; left: 12px; top: -48px; background: var(--retro-14); color: var(--retro-black);
      padding: 8px 10px; border-radius: 8px; z-index: 9999; text-decoration: none; font-weight: 700;
    }
    .skip-link:focus { top: 12px; }
    .container { width: min(1200px, 94vw); margin: 0 auto; padding: 0 16px 40px; }
    h1, h2, h3 { letter-spacing: 0.08em; text-wrap: balance; color: var(--ui-heading); }
    h1 { font-size: 1.4rem; margin: 0 0 10px; font-weight: 700; }
    h2 { font-size: 1.15rem; margin: 0 0 12px; font-weight: 700; }
    h3 { font-size: 1.05rem; margin: 0 0 8px; color: var(--cream); font-weight: 700; }
    h4.section-label {
      margin: 0 0 6px; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--cream); font-weight: 700;
    }
    .lead { color: var(--ui-text-muted); max-width: 78ch; margin: 0; }
    .box-level-1 {
      border: 2px solid var(--ui-border); border-radius: 8px;
      margin-bottom: 16px;
    }
    .segment-has-bg {
      position: relative; overflow: hidden;
      background: var(--bg-panel);
    }
    .segment-has-bg > .segment-content {
      position: relative; z-index: 2; padding: 16px;
    }
    .segment-bg {
      position: absolute; inset: 0; z-index: 0;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; pointer-events: none;
    }
    .ascii-bg-layer {
      position: absolute; top: 50%; left: 50%;
      margin: 0; padding: 0; border: 0;
      font-family: "VT323", monospace; font-size: 16px; line-height: 1;
      white-space: pre; color: var(--retro-14);
      opacity: var(--ascii-bg-opacity);
      transform: translate(-50%, -50%) scale(1);
      transform-origin: center center;
    }
    .segment-scrim {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
      background: var(--segment-scrim);
    }
    .hero-panel.segment-has-bg { --ascii-bg-opacity: 0.34; --segment-scrim: color-mix(in srgb, var(--bg-panel) 66%, transparent); }
    .attack-card.segment-has-bg { --ascii-bg-opacity: 0.40; --segment-scrim: color-mix(in srgb, var(--bg-panel) 72%, transparent); }
    .hud-card.segment-has-bg { --ascii-bg-opacity: 0.44; --segment-scrim: color-mix(in srgb, var(--bg-card) 68%, transparent); }
    .hud-card.segment-has-bg > .segment-content { padding: 12px; }
    .badge-row { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0; }
    .badge {
      display: inline-block; padding: 3px 8px; border-radius: 3px; border: 1px solid var(--ui-border);
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.3px;
    }
    .badge.open { background: var(--proto-1); color: var(--retro-black); }
    .badge.filtered { background: var(--proto-5); color: var(--retro-black); }
    .badge.closed { background: var(--proto-6); color: var(--retro-13); }
    .badge.anal { background: var(--retro-8); color: var(--paper); }
    .badge.proto-tcp { background: var(--extra-3); color: var(--retro-0); }
    nav.top-nav { display: flex; flex-wrap: wrap; gap: 8px; margin: 14px 0 4px; }
    .report-btn {
      display: inline-block; padding: 8px 12px; border-radius: 6px; border: 2px solid var(--ui-btn-border);
      background: var(--ui-btn-bg); color: var(--ui-btn-fg); font-size: 0.84rem; font-weight: 700;
      text-decoration: none; transition: background 0.1s ease, transform 0.1s ease;
    }
    .report-btn:hover { background: var(--ui-btn-hover-bg); color: var(--ui-btn-hover-fg); transform: translateY(-1px); }
    .hud-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin-bottom: 12px; }
    .hud-card {
      border: 2px solid var(--ui-border); border-radius: 8px;
      background: var(--bg-card);
    }
    .hud-card p { margin: 8px 0 0; color: var(--ui-text-muted); font-size: 0.84rem; }
    .metric-row { display: flex; justify-content: space-between; gap: 12px; padding: 6px 0; border-bottom: 1px solid var(--retro-2); font-variant-numeric: tabular-nums; }
    .callout {
      border-left: 3px solid var(--accent); padding: 10px 12px; margin-top: 10px;
      background: rgba(246, 205, 38, 0.07); color: var(--cream); border-radius: 0 6px 6px 0;
    }
    .callout--result { border-left-color: var(--note-signal); }
    .toolbar { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin: 12px 0; }
    #layer-filter {
      background: var(--ui-field-bg); color: var(--ui-field-fg); border: 1.5px solid var(--ui-field-border);
      border-radius: 6px; padding: 8px 10px; font-family: inherit; font-size: 0.84rem;
    }
    .attack-grid { display: grid; gap: 14px; }
    .attack-head { margin-bottom: 4px; }
    .script-tag { margin: 4px 0 0; color: var(--ui-text-muted); font-size: 0.78rem; }
    .hands-on { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--retro-2); }
    pre.mono, .payload-sample {
      background: color-mix(in srgb, var(--retro-0) 92%, transparent); border: 1px solid var(--ui-border); border-radius: 4px;
      padding: 10px; color: var(--paper); font-size: 0.72rem; line-height: 1.35;
      white-space: pre-wrap; word-break: break-word; margin: 0 0 10px; max-height: 280px; overflow-y: auto;
    }
    .outcome-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .outcome-box {
      padding: 10px; border-radius: 6px; border: 1px solid var(--ui-border); font-size: 0.82rem;
    }
    .outcome-box.expected { background: color-mix(in srgb, var(--retro-1) 90%, rgba(246, 205, 38, 0.12)); border-left: 3px solid var(--accent); }
    .outcome-box.actual { background: color-mix(in srgb, var(--retro-1) 90%, rgba(255, 62, 62, 0.12)); border-left: 3px solid var(--note-signal); }
    .outcome-box p { margin: 0; color: var(--ui-text-main); }
    .defender-note { margin: 0; font-size: 0.8rem; color: var(--ui-text-muted); }
    .defender-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .defender-grid article { border-left: 4px solid var(--cat-analyst); }
    .refs li { margin: 6px 0; }
    .sr-anchor { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
    footer { margin-top: 8px; text-align: center; color: var(--ui-text-muted); font-size: 0.78rem; }
    .hidden-card { display: none !important; }
    @media (max-width: 900px) {
      .hud-grid { grid-template-columns: 1fr 1fr; }
      .defender-grid, .outcome-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) { .hud-grid { grid-template-columns: 1fr; } }
    @media (prefers-reduced-motion: reduce) { .report-btn { transition: none; } }
  </style>
</head>
