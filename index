  <script>
    function fitAsciiBg(pre) {
      const box = pre.closest('.segment-bg');
      if (!box || !box.clientWidth) return;
      pre.style.transform = 'translate(-50%, -50%) scale(1)';
      pre.style.fontSize = '16px';
      const natW = pre.scrollWidth;
      const natH = pre.scrollHeight;
      if (!natW || !natH) return;
      const pad = 12;
      const scale = Math.min((box.clientWidth - pad) / natW, (box.clientHeight - pad) / natH);
      const s = Math.max(0.04, Math.min(scale, 2));
      pre.style.transform = 'translate(-50%, -50%) scale(' + s + ')';
    }
    function fitAllAsciiBg() {
      document.querySelectorAll('.ascii-bg-layer').forEach(fitAsciiBg);
    }
    fitAllAsciiBg();
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(fitAllAsciiBg);
    }
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(fitAllAsciiBg, 120);
    });

    const filter = document.getElementById('layer-filter');
    const cards = document.querySelectorAll('.attack-card');
    const counter = document.getElementById('visible-count');
    function applyFilter() {
      const v = filter.value;
      let n = 0;
      cards.forEach(card => {
        const show = v === 'all' || card.dataset.layer === v;
        card.classList.toggle('hidden-card', !show);
        if (show) n++;
      });
      counter.textContent = n + ' visible';
    }
    filter.addEventListener('change', applyFilter);
    applyFilter();
  </script>
